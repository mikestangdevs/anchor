  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikestangdevs/anchor"
  },
  "homepage": "https://github.com/mikestangdevs/anchor#readme",
  "bugs": {
    "url": "https://github.com/mikestangdevs/anchor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
