{
  "name": "anchor-acr",
  "version": "0.1.0-beta.1",
  "description": "Anchor — agent-first context infrastructure. Ingest docs, search with citations, serve via MCP.",
  "type": "module",
  "bin": {
    "acr": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "postinstall": "node dist/postinstall.js",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "openai": "^4.75.0",
    "postgres": "^3.4.0",
    "turndown": "^7.2.0",
    "@octokit/rest": "^20.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@acr/annotations": "workspace:*",
    "@acr/config": "workspace:*",
    "@acr/connectors": "workspace:*",
    "@acr/core": "workspace:*",
    "@acr/db": "workspace:*",
    "@acr/embeddings": "workspace:*",
    "@acr/parser": "workspace:*",
    "@acr/retrieval": "workspace:*",
    "@acr/types": "workspace:*",
    "@types/node": "^25.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "anchor",
    "acr",
    "context",
    "agent",
    "mcp",
    "retrieval",
    "embeddings",
    "documentation",
    "rag",
    "citations",
    "semantic-search"
  ],
