# ─── Required ───────────────────────────────────────────────
# Database (Supabase recommended, local Postgres also works)
#
# Supabase:
#   Dashboard → Project Settings → Database → Connection string → URI
#   Use Session mode (port 5432), not Transaction mode (6543)
#
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Local:
# DATABASE_URL=postgresql://acr:acr@localhost:5432/agent_context_repo
DATABASE_URL=

# Embedding provider (OpenAI default, any compatible endpoint supported)
# Get a key: https://platform.openai.com/api-keys
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=

# ─── Optional ───────────────────────────────────────────────
# GitHub PAT — increases API rate limit from 60 to 5000 req/hr
# Only needed for github_repo sources
# GITHUB_TOKEN=ghp_...
